# Containers with Middleware — Local Development Environment Variables
#
# USAGE:
#   1. Copy this file:  cp .env.example .env
#   2. Edit .env with your actual values
#   3. Run: docker compose up -d
#
# IMPORTANT: .env is listed in .gitignore — never commit it to Git.
#            This file (.env.example) is safe to commit — it contains no real secrets.

# =============================================================================
# PostgreSQL
# =============================================================================

# Password for the local hermes database user.
# Default 'hermes' is acceptable for local development only.
# Never use this value in staging or production.
POSTGRES_PASSWORD=hermes

# =============================================================================
# LocalStack Auth (disabled by default — community edition)
# =============================================================================
#
# LocalStack enforces auth for the free tier from 2026-03-23.
#
# To enable authenticated mode (Option A):
#   1. Obtain a token from https://app.localstack.cloud/
#   2. Uncomment LOCALSTACK_AUTH_TOKEN below and set your token
#   3. In docker-compose.yml, uncomment the LOCALSTACK_AUTH_TOKEN line
#      under the localstack service environment section
#
# LOCALSTACK_AUTH_TOKEN=<your-localstack-auth-token-here>

# =============================================================================
# mTLS Certificate Passwords (local-dev/certs/generate-certs.sh)
# =============================================================================
#
# Passwords for the keystores generated by generate-certs.sh.
# Change these from the default before running the script if you want
# non-default passwords. Must match what is configured in application-local.yml.
#
# KEYSTORE_PASSWORD   — password for client-keystore.p12 (JCSMP keystore)
# TRUSTSTORE_PASSWORD — password for truststore.jks      (JCSMP truststore)
KEYSTORE_PASSWORD=changeit
TRUSTSTORE_PASSWORD=changeit

# =============================================================================
# Solace (local Docker — values must match docker-compose.yml)
# =============================================================================

# These match the values set in docker-compose.yml environment block.
# Change both here and in docker-compose.yml if you override the defaults.
SOLACE_ADMIN_USERNAME=admin
SOLACE_ADMIN_PASSWORD=admin

# =============================================================================
# Application (used by Spring Boot local profile — US-E0-005)
# =============================================================================

# These will be consumed by application-local.yml in Sprint 1 Story US-E0-005.
# Defined here now so the .env file is complete when the app profile is added.
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/hermes
SPRING_DATASOURCE_USERNAME=hermes
SPRING_DATASOURCE_PASSWORD=hermes

SOLACE_HOST=localhost
SOLACE_PORT=55555
SOLACE_VPN=default

AWS_ENDPOINT_OVERRIDE=http://localhost:4566
AWS_REGION=us-east-1
# LocalStack does not validate real credentials — use placeholder values
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
