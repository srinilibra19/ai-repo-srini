# =============================================================================
# .gitignore — Hermes (Containers with Middleware)
# =============================================================================

# -----------------------------------------------------------------------------
# Security — NEVER commit secrets, certificates, or keys
# These patterns are the last line of defence against credential leakage.
# -----------------------------------------------------------------------------

# Local dev TLS certificates and keystores (generated by local-dev/certs/generate-certs.sh)
*.p12
*.jks
*.pem
*.key
*.crt
*.csr
*.srl

# Environment files — contain local overrides and sensitive defaults
.env
.env.*
*.env
!.env.example

# AWS credentials
.aws/credentials

# -----------------------------------------------------------------------------
# Java / Maven build artefacts
# -----------------------------------------------------------------------------
target/
*.class
*.jar
*.war
*.ear

# Maven wrapper download cache
.mvn/repository/

# Maven Surefire / Failsafe reports (regenerated on every build)
surefire-reports/
failsafe-reports/

# OWASP Dependency-Check reports (contain dependency metadata, not committed)
dependency-check-report.*

# -----------------------------------------------------------------------------
# Terraform
# -----------------------------------------------------------------------------

# Local state files — remote state (S3 + DynamoDB) is mandatory; local state is forbidden
*.tfstate
*.tfstate.*
*.tfstate.backup

# Terraform plan outputs — contain sensitive resource data
*.tfplan

# Terraform working directories
**/.terraform/
# NOTE: .terraform.lock.hcl is intentionally NOT excluded — it pins provider
# plugin versions and must be committed (equivalent to package-lock.json).

# Terraform variable files — only exclude auto-loaded and secret override files.
# terraform.tfvars in each environment directory IS committed (contains non-sensitive
# config: region, CIDR, cluster size). Required for reproducible terraform plan.
*.auto.tfvars
*.secret.tfvars
!*.tfvars.example

# Terraform crash logs
crash.log
crash.*.log

# -----------------------------------------------------------------------------
# IDE and OS artefacts
# -----------------------------------------------------------------------------

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# VS Code
.vscode/
*.code-workspace

# Eclipse / STS
.classpath
.project
.settings/
bin/

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Linux
*~

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
# Docker build context cache
.dockerignore.bak

# -----------------------------------------------------------------------------
# Helm
# -----------------------------------------------------------------------------
# Helm chart lock files are committed; chart archives are not
*.tgz
charts/*.tgz
